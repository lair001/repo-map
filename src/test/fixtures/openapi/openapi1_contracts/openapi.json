{
  "openapi": "3.0.3",
  "info": {
    "title": "Fixture Pets API",
    "version": "1.0.0",
    "description": "fixture json description must not be emitted raw"
  },
  "servers": [
    {
      "url": "https://user:fake-openapi-json-server-secret@api.example.invalid/v1"
    }
  ],
  "externalDocs": {
    "url": "https://docs.example.invalid/pets"
  },
  "paths": {
    "/pets": {
      "get": {
        "operationId": "listPets",
        "tags": ["pets"],
        "summary": "List pets",
        "description": "fixture operation description must not be emitted raw",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Pet"
                }
              }
            }
          },
          "400": {
            "description": "bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./schemas/error.yaml#/Error"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createPet",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PetInput"
              },
              "example": {
                "password": "fake-openapi-json-password"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "https://api.example.invalid/schemas/pet.yaml#/Pet"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Pet": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "token": {
            "type": "string",
            "example": "fake-openapi-json-token"
          }
        }
      },
      "PetInput": {
        "type": "object"
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  },
  "security": [
    {
      "ApiKeyAuth": []
    }
  ]
}
